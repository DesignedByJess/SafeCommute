# Server
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/safecommute
DATABASE_URL_TEST=postgresql://user:password@localhost:5432/safecommute_test

# CORS
CORS_ORIGIN=http://localhost:5173

# Security
CSRF_SECRET=change-me-to-a-random-string
HMAC_SECRET=change-me-to-a-random-64-char-string

# Encryption
MASTER_KEY=change-me-to-32-char-key-for-envelope-encryption
PHONE_KEY=change-me-to-32-char-key-for-phone-encryption

# Supabase Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Flutterwave
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-xxxx
FLUTTERWAVE_SECRET_KEY=FLWSECK-xxxx
FLUTTERWAVE_ENCRYPTION_KEY=xxxx
FLUTTERWAVE_SECRET_HASH=xxxx

# Notifications
WHATSAPP_API_TOKEN=your-whatsapp-api-token
WHATSAPP_PHONE_NUMBER_ID=your-whatsapp-phone-number-id
AFRICA_TALKING_API_KEY=your-africa-talking-key
AFRICA_TALKING_USERNAME=safecommute
AFRICA_TALKING_SENDER_ID=SafeCmmt
AFRICA_TALKING_SANDBOX=false
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+12345678901

# Google APIs
GOOGLE_MAPS_API_KEY=your-google-maps-key
GOOGLE_VISION_API_KEY=your-google-vision-key

# Logging
LOG_LEVEL=info
